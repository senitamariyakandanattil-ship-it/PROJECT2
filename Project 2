        "class Account:\n",
        "    MIN_BALANCE = 500\n",
        "    DAILY_WITHDRAW_LIMIT = 10000\n",
        "\n",
        "    def __init__(self, acc_no, name, balance):\n",
        "        self.acc_no = acc_no\n",
        "        self.name = name\n",
        "        self.balance = balance\n",
        "        self.transactions = []\n",
        "        self.daily_withdrawn = 0\n",
        "\n",
        "        self.transactions.append(\n",
        "            f\"Account Created with Balance: ₹{balance}\"\n",
        "        )\n",
        "\n",
        "    def deposit(self, amount):\n",
        "        if amount <= 0:\n",
        "            print(\"Invalid deposit amount!\")\n",
        "            return\n",
        "\n",
        "        self.balance += amount\n",
        "        self.transactions.append(f\"Deposited ₹{amount}\")\n",
        "        print(\"Deposit Successful!\")\n",
        "\n",
        "    def withdraw(self, amount):\n",
        "        if amount <= 0:\n",
        "            print(\"Invalid withdrawal amount!\")\n",
        "            return\n",
        "\n",
        "        if self.daily_withdrawn + amount > self.DAILY_WITHDRAW_LIMIT:\n",
        "            print(\"Daily withdrawal limit exceeded!\")\n",
        "            return\n",
        "\n",
        "        if self.balance - amount < self.MIN_BALANCE:\n",
        "            print(\"Minimum balance must be maintained!\")\n",
        "            return\n",
        "\n",
        "        self.balance -= amount\n",
        "        self.daily_withdrawn += amount\n",
        "        self.transactions.append(f\"Withdrawn ₹{amount}\")\n",
        "        print(\"Withdrawal Successful!\")\n",
        "\n",
        "    def transfer(self, receiver, amount):\n",
        "        if amount <= 0:\n",
        "            print(\"Invalid transfer amount!\")\n",
        "            return\n",
        "\n",
        "        if self.balance - amount < self.MIN_BALANCE:\n",
        "            print(\"Insufficient balance!\")\n",
        "            return\n",
        "\n",
        "        self.balance -= amount\n",
        "        receiver.balance += amount\n",
        "\n",
        "        self.transactions.append(\n",
        "            f\"Transferred ₹{amount} to A/C {receiver.acc_no}\"\n",
        "        )\n",
        "        receiver.transactions.append(\n",
        "            f\"Received ₹{amount} from A/C {self.acc_no}\"\n",
        "        )\n",
        "\n",
        "        print(\"Transfer Successful!\")\n",
        "\n",
        "    def mini_statement(self):\n",
        "        print(\"\\n--- Mini Statement ---\")\n",
        "        for t in self.transactions:\n",
        "            print(t)\n",
        "        print(\"Current Balance: ₹\", self.balance)\n",
        "\n",
        "\n",
        "accounts = {}\n",
        "\n",
        "while True:\n",
        "    print(\"\\n===== MINI BANKING SYSTEM =====\")\n",
        "    print(\"1. Create Account\")\n",
        "    print(\"2. Deposit\")\n",
        "    print(\"3. Withdraw\")\n",
        "    print(\"4. Transfer Funds\")\n",
        "    print(\"5. Mini Statement\")\n",
        "    print(\"6. Exit\")\n",
        "\n",
        "    choice = input(\"Enter Choice: \")\n",
        "\n",
        "    if choice == \"1\":\n",
        "        acc_no = input(\"Enter Account Number: \")\n",
        "\n",
        "        if acc_no in accounts:\n",
        "            print(\"Account already exists!\")\n",
        "            continue\n",
        "\n",
        "        name = input(\"Enter Name: \")\n",
        "        balance = float(input(\"Enter Initial Balance: \"))\n",
        "\n",
        "        if balance < 500:\n",
        "            print(\"Minimum opening balance is ₹500\")\n",
        "            continue\n",
        "\n",
        "        accounts[acc_no] = Account(acc_no, name, balance)\n",
        "        print(\"Account Created Successfully!\")\n",
        "\n",
        "    elif choice == \"2\":\n",
        "        acc_no = input(\"Enter Account Number: \")\n",
        "\n",
        "        if acc_no not in accounts:\n",
        "            print(\"Account not found!\")\n",
        "            continue\n",
        "\n",
        "        amount = float(input(\"Enter Amount: \"))\n",
        "        accounts[acc_no].deposit(amount)\n",
        "\n",
        "    elif choice == \"3\":\n",
        "        acc_no = input(\"Enter Account Number: \")\n",
        "\n",
        "        if acc_no not in accounts:\n",
        "            print(\"Account not found!\")\n",
        "            continue\n",
        "\n",
        "        amount = float(input(\"Enter Amount: \"))\n",
        "        accounts[acc_no].withdraw(amount)\n",
        "\n",
        "    elif choice == \"4\":\n",
        "        sender = input(\"Enter Sender Account Number: \")\n",
        "        receiver = input(\"Enter Receiver Account Number: \")\n",
        "\n",
        "        if sender not in accounts or receiver not in accounts:\n",
        "            print(\"Invalid account number!\")\n",
        "            continue\n",
        "\n",
        "        amount = float(input(\"Enter Amount: \"))\n",
        "        accounts[sender].transfer(accounts[receiver], amount)\n",
        "\n",
        "    elif choice == \"5\":\n",
        "        acc_no = input(\"Enter Account Number: \")\n",
        "\n",
        "        if acc_no not in accounts:\n",
        "            print(\"Account not found!\")\n",
        "            continue\n",
        "\n",
        "        accounts[acc_no].mini_statement()\n",
        "\n",
        "    elif choice == \"6\":\n",
        "        print(\"Thank You!\")\n",
        "        break\n",
        "\n",
        "    else:\n",
        "        print(\"Invalid Choice!\")"
